<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Барабан: Выиграй Бамбук! 🎋</title>
    <style>
        body {
            font-family: 'Arial', sans-serif;
            background-color: #1a1a1a;
            color: #ffffff;
            text-align: center;
            margin: 0;
            padding: 20px;
        }

        h1 { color: #4CAF50; margin-bottom: 5px; }
        .subtitle { color: #aaa; margin-bottom: 30px; }

        /* Счетчик бамбука */
        .counter-box {
            font-size: 24px;
            background: #2a2a2a;
            padding: 10px 20px;
            border-radius: 50px;
            display: inline-block;
            border: 2px solid #4CAF50;
            margin-bottom: 20px;
        }

        /* Окошко информации W */
        .status-w {
            width: 200px;
            background: #333;
            border: 4px solid #888;
            border-radius: 15px;
            padding: 10px;
            margin: 0 auto 20px auto;
            font-size: 28px;
            font-weight: bold;
            min-height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 15px rgba(255,255,255,0.1);
        }

        /* Стрелочка-указатель сверху */
        .pointer {
            font-size: 30px;
            color: #ccff00;
            margin-bottom: -5px;
            animation: bounce 1s infinite;
        }
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-5px); }
        }

        /* Рулетка */
        .roulette-container {
            width: 100%;
            max-width: 600px;
            height: 130px;
            background: #222;
            border: 4px solid #444;
            border-radius: 10px;
            margin: 0 auto 30px auto;
            overflow: hidden;
            position: relative;
            box-shadow: inset 0 0 20px #000;
        }

        .tape {
            display: flex;
            position: absolute;
            left: 0;
            top: 15px;
            height: 100px;
            transition: none;
        }

        /* Стили предметов в рулетке */
        .item {
            min-width: 100px;
            max-width: 100px;
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 45px;
            font-weight: bold;
            box-sizing: border-box;
            border-right: 1px solid #333;
        }
        .item.loose { color: #ff3333; }
        
        /* Картинка бамбука со скрытием белого фона */
        .bamboo-img {
            width: 80px;
            height: 80px;
            object-fit: contain;
            mix-blend-mode: color-burn; /* Убирает белый фон картинки */
            background-color: transparent;
        }

        /* Кнопка крутить */
        .spin-btn {
            background: linear-gradient(145px, #4CAF50, #388E3C);
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 22px;
            font-weight: bold;
            border-radius: 10px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(76,175,80,0.4);
            transition: 0.2s;
        }
        .spin-btn:hover { transform: scale(1.05); }
        .spin-btn:disabled { background: #555; cursor: not-allowed; box-shadow: none; }

        /* Промокод в углу экрана */
        .promo-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #252525;
            padding: 15px;
            border-radius: 10px;
            border: 1px solid #444;
            text-align: left;
        }
        .promo-container input {
            padding: 8px;
            border: 1px solid #555;
            background: #111;
            color: #fff;
            border-radius: 5px;
            width: 120px;
            font-weight: bold;
        }
        .promo-container button {
            padding: 8px 12px;
            background: #4CAF50;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            margin-left: 5px;
        }
    </style>
</head>
<body>

    <h1>Испытай удачу! 🎋</h1>
    <div class="subtitle">Специально для стрима</div>

    <div class="counter-box">
        Баланс: <span id="bamboo-count">0</span> 🎋
    </div>

    <div class="status-w" id="window-w">W</div>

    <div class="pointer">▼</div>
    
    <div class="roulette-container">
        <div class="tape" id="tape"></div>
    </div>

    <button class="spin-btn" id="spin-btn" onclick="startSpin()">ПОКРУТИТЬ!</button>

    <div class="promo-container">
        <label style="font-size: 12px; color: #888; display:block; margin-bottom:5px;">У вас есть промокод?</label>
        <input type="text" id="promo-input" placeholder="КОД">
        <button onclick="activatePromo()">ОК</button>
        <div id="promo-msg" style="font-size: 12px; margin-top: 5px;"></div>
    </div>

    <script>
        let score = 0;
        let isSpinning = false;
        let usedPromo = false;

        // Прямая ссылка на твою картинку BambooSeed из твоего же гитхаба
        const bambooImgUrl = "BambooSeed.png"; 

        const tape = document.getElementById('tape');
        const windowW = document.getElementById('window-w');
        const spinBtn = document.getElementById('spin-btn');

        // Генерируем ленту рулетки перед стартом
        function generateTape() {
            tape.innerHTML = '';
            tape.style.transition = 'none';
            tape.style.left = '0px';

            // Создаем 60 ячеек, чтобы лента казалась бесконечной при прокрутке
            for(let i = 0; i < 60; i++) {
                let item = document.createElement('div');
                item.classList.add('item');

                // 25-я ячейка будет финишной (куда приедет рулетка)
                if (i === 25) {
                    // Заранее решаем, выиграл или нет (Шанс 50%)
                    if (Math.random() > 0.5) {
                        item.innerHTML = `<img src="${bambooImgUrl}" class="bamboo-img" alt="🎋">`;
                        item.dataset.result = "win";
                    } else {
                        item.innerText = "X";
                        item.classList.add('loose');
                        item.dataset.result = "lose";
                    }
                } else {
                    // Все остальные ячейки просто заполняем случайными X и бамбуками для вида
                    if (Math.random() > 0.7) {
                        item.innerHTML = `<img src="${bambooImgUrl}" class="bamboo-img" alt="🎋">`;
                    } else {
                        item.innerText = "X";
                        item.classList.add('loose');
                    }
                }
                tape.appendChild(item);
            }
        }

        // Запуск анимации кручения
        function startSpin() {
            if (isSpinning) return;
            isSpinning = true;
            spinBtn.disabled = true;
            windowW.innerText = "Крутим...";
            windowW.style.color = "#fff";
            windowW.style.borderColor = "#888";

            generateTape();

            // Рассчитываем сдвиг ленты, чтобы 25-й элемент встал ровно по центру (под стрелочку)
            // Ширина контейнера 600px, центр — 300px. Ширина ячейки — 100px.
            const targetLeft = -(25 * 100) + 250; 
            
            // Добавим немного случайного смещения внутри ячейки для реализма
            const randomOffset = Math.floor(Math.random() * 40) - 20; 

            // Запускаем плавную анимацию через CSS
            setTimeout(() => {
                tape.style.transition = "all 4s cubic-bezier(0.1, 0.8, 0.1, 1)";
                tape.style.left = (targetLeft + randomOffset) + "px";
            }, 50);

            // Ждем окончания анимации (4 секунды)
            setTimeout(() => {
                const finalItem = tape.children[25];
                if (finalItem.dataset.result === "win") {
                    windowW.innerText = "ВЫИГРАЛ!";
                    windowW.style.color = "#4CAF50";
                    windowW.style.borderColor = "#4CAF50";
                    score += 1;
                    document.getElementById('bamboo-count').innerText = score;
                } else {
                    windowW.innerText = "ПРОИГРАЛ";
                    windowW.style.color = "#ff3333";
                    windowW.style.borderColor = "#ff3333";
                }
                isSpinning = false;
                spinBtn.disabled = false;
            }, 4100);
        }

        // Логика промокода
        function activatePromo() {
            const input = document.getElementById('promo-input').value.trim();
            const msg = document.getElementById('promo-msg');

            if (usedPromo) {
                msg.innerText = "Вы уже вводили код!";
                msg.style.color = "#ff3333";
                return;
            }

            if (input === "FelliikWWW") {
                score += 5;
                document.getElementById('bamboo-count').innerText = score;
                usedPromo = true;
                msg.innerText = "Успешно! +5 бамбуков 🎋";
                msg.style.color = "#4CAF50";
                document.getElementById('promo-input').disabled = true;
            } else {
                msg.innerText = "Неверный код!";
                msg.style.color = "#ff3333";
            }
        }

        // Первая генерация при загрузке страницы
        generateTape();
    </script>
</body>
</html>
